# ══════════════════════════════════════════════════════════════
# WORLD AI — Variables d'Environnement
# ══════════════════════════════════════════════════════════════
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplir TOUTES les valeurs (surtout les mots de passe)
# 3. JAMAIS committer le fichier .env
# ══════════════════════════════════════════════════════════════

# ── Infrastructure ─────────────────────────────────────────────
WORLDAI_DOMAIN=your-domain.com
WORLDAI_ACME_EMAIL=your-email@example.com
WORLDAI_ENV=production

# ── API Keys LLM ──────────────────────────────────────────────
WORLDAI_OPENROUTER_API_KEY=
WORLDAI_ANTHROPIC_API_KEY=

# ── Canal Telegram ────────────────────────────────────────────
# https://t.me/BotFather → /newbot
WORLDAI_TELEGRAM_BOT_TOKEN=

# ── Canal Discord ─────────────────────────────────────────────
# https://discord.com/developers/applications
WORLDAI_DISCORD_BOT_TOKEN=
WORLDAI_DISCORD_GUILD_ID=

# ── Canal Slack ───────────────────────────────────────────────
# https://api.slack.com/apps → OAuth Tokens
WORLDAI_SLACK_BOT_TOKEN=
WORLDAI_SLACK_SIGNING_SECRET=
# Socket Mode — laisser vide si webhooks HTTP préférés
WORLDAI_SLACK_APP_TOKEN=

# ── Canal WhatsApp ────────────────────────────────────────────
# Mode : twilio | web (whatsapp-web.py)
WORLDAI_WHATSAPP_MODE=twilio
# Twilio — https://console.twilio.com
WORLDAI_TWILIO_ACCOUNT_SID=
WORLDAI_TWILIO_AUTH_TOKEN=
WORLDAI_TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Canal Email (IMAP/SMTP) ───────────────────────────────────
WORLDAI_EMAIL_IMAP_HOST=imap.gmail.com
WORLDAI_EMAIL_IMAP_PORT=993
WORLDAI_EMAIL_SMTP_HOST=smtp.gmail.com
WORLDAI_EMAIL_SMTP_PORT=587
WORLDAI_EMAIL_ADDRESS=
# Pour Gmail : mot de passe d'application (pas le mot de passe principal)
WORLDAI_EMAIL_PASSWORD=

# ── Canal iMessage ────────────────────────────────────────────
# true uniquement si macOS local avec AppleScript disponible
WORLDAI_IMESSAGE_ENABLED=false

# ── Canal Web Chat ────────────────────────────────────────────
# JWT secret pour authentifier le widget embarquable
# Générer avec : openssl rand -hex 32
WORLDAI_WEBCHAT_SECRET=

# ── Canal API REST publique ───────────────────────────────────
# Clé API pour intégrations tierces directes
# Générer avec : openssl rand -hex 32
WORLDAI_API_PUBLIC_KEY=

# ── PostgreSQL (base partagée) ────────────────────────────────
WORLDAI_POSTGRES_USER=worldai
WORLDAI_POSTGRES_PASSWORD=
WORLDAI_POSTGRES_DB=worldai

# ── Redis ─────────────────────────────────────────────────────
WORLDAI_REDIS_PASSWORD=

# ── Memgraph ──────────────────────────────────────────────────
WORLDAI_MEMGRAPH_USER=memgraph
WORLDAI_MEMGRAPH_PASSWORD=

# ── Qdrant ────────────────────────────────────────────────────
WORLDAI_QDRANT_API_KEY=

# ── URLs internes (ne pas modifier en Docker) ─────────────────
WORLDAI_MEMGRAPH_URI=bolt://memgraph:7687
WORLDAI_QDRANT_URL=http://qdrant:6333
WORLDAI_REDIS_URL=redis://redis:6379

# ── LLM Routing ───────────────────────────────────────────────
WORLDAI_LLM_BUDGET_MODEL=deepseek/deepseek-chat
WORLDAI_LLM_MID_MODEL=meta-llama/llama-4-scout
WORLDAI_LLM_FRONTIER_MODEL=anthropic/claude-opus-4-6
WORLDAI_CONFIDENCE_THRESHOLD=0.75
WORLDAI_SIMULATION_THRESHOLD=0.40

# ── Local Inference (xLAM-2 via llama.cpp) ───────────────────
# Laisser vide pour désactiver. Format : http://localhost:8080/v1
WORLDAI_XLAM_LOCAL_URL=

# ── n8n ───────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
WORLDAI_N8N_ENCRYPTION_KEY=

# ── Langfuse ──────────────────────────────────────────────────
WORLDAI_LANGFUSE_SECRET_KEY=
WORLDAI_LANGFUSE_PUBLIC_KEY=
# Générer avec : openssl rand -hex 32
WORLDAI_LANGFUSE_NEXTAUTH_SECRET=
# Générer avec : openssl rand -hex 16
WORLDAI_LANGFUSE_SALT=

# ── Dify ──────────────────────────────────────────────────────
# Générer avec : openssl rand -hex 32
WORLDAI_DIFY_SECRET_KEY=
# Version images Dify (https://github.com/langgenius/dify/releases)
WORLDAI_DIFY_VERSION=0.6.14

# ── MCP Servers natifs ────────────────────────────────────────
# Brave Search API key — https://brave.com/search/api/
WORLDAI_BRAVE_API_KEY=
# Sandbox root pour le FilesystemMCP (dans le container Docker)
WORLDAI_MCP_SANDBOX_ROOT=/data/user
# Timeout HTTP (secondes) pour web_fetch
WORLDAI_MCP_FETCH_TIMEOUT_S=15
# Taille max body fetch (bytes) — 512 KB par défaut
WORLDAI_MCP_FETCH_MAX_BYTES=524288
# Serveurs actifs (séparés par virgule)
WORLDAI_MCP_ENABLED_SERVERS=filesystem,web,email,calendar,browser

# ── MCP Connecteurs tiers (activer selon disponibilité) ───────
# Notion — https://www.notion.so/my-integrations
WORLDAI_MCP_NOTION_TOKEN=

# GitHub — https://github.com/settings/tokens
WORLDAI_MCP_GITHUB_TOKEN=

# Google Drive — chemin JSON OAuth2 (https://console.cloud.google.com)
WORLDAI_MCP_GDRIVE_CREDENTIALS=

# Linear — https://linear.app/settings/api
WORLDAI_MCP_LINEAR_API_KEY=

# Airtable — https://airtable.com/account
WORLDAI_MCP_AIRTABLE_API_KEY=

# Stripe — LECTURE SEULE obligatoire
# https://dashboard.stripe.com/apikeys (restricted key, read only)
WORLDAI_MCP_STRIPE_SECRET_KEY=

# PostgreSQL externe (hors container — ex: Supabase, Neon)
WORLDAI_MCP_POSTGRES_URL=
